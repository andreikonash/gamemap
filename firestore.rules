rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isSuperAdmin() {
      return isSignedIn() && request.auth.token.admin == true;
    }

    function isOrganizerOf(gameId) {
      return isSignedIn()
        && get(/databases/$(database)/documents/games/$(gameId)).data.organizerId == request.auth.uid;
    }

    match /games/{gameId} {
      allow read: if true;
      allow create: if isSignedIn()
        && request.resource.data.status == 'open'
        && request.resource.data.seatsTaken == 0
        && request.resource.data.seatsTotal > 0;
      allow delete: if false;
      allow update: if isSignedIn()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['seatsTaken'])
        && (
          (request.resource.data.seatsTaken == resource.data.seatsTaken + 1
            && request.resource.data.seatsTaken <= resource.data.seatsTotal)
          || (request.resource.data.seatsTaken == resource.data.seatsTaken - 1
            && request.resource.data.seatsTaken >= 0)
        );
    }

    match /registrations/{registrationId} {
      allow read: if isSignedIn()
        && (resource.data.userId == request.auth.uid
          || isOrganizerOf(resource.data.gameId)
          || isSuperAdmin());
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isSignedIn()
        && resource.data.userId == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status']);
      allow delete: if isSignedIn()
        && (resource.data.userId == request.auth.uid
          || isOrganizerOf(resource.data.gameId)
          || isSuperAdmin());
    }

    match /teams/{teamId} {
      allow read: if true;
      allow write: if false;
    }

    match /teamMemberships/{membershipId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow update: if false;
    }
  }
}
