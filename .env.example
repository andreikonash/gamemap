# Leave any key empty to run that part in demo (mock) mode:
# - no VITE_GOOGLE_MAPS_API_KEY  -> a fake in-app map is shown
# - no VITE_FIREBASE_API_KEY     -> auth, games and registrations are mocked in-memory

# Google Maps
VITE_GOOGLE_MAPS_API_KEY=

# Firebase
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
